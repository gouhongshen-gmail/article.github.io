<style>
  .footer {
    background: var(--color-ink);
    color: var(--color-parchment);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 24px 24px;
  }

  .footer-columns {
    display: flex;
    flex-direction: column;
    gap: 32px;
    margin-bottom: 32px;
  }

  @media (min-width: 768px) {
    .footer-columns {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-tagline {
    font-size: 0.9rem;
    opacity: 0.7;
    margin: 0;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
  }

  .footer-heading {
    font-weight: 600;
    font-size: 1rem;
    margin: 0;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-links a {
    color: var(--color-parchment);
    text-decoration: none;
    opacity: 0.8;
    font-size: 0.9rem;
    transition: opacity 0.2s;
  }

  .footer-links a:hover {
    opacity: 1;
    text-decoration: underline;
  }

  .footer-divider {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    margin: 0 0 16px;
  }

  .footer-bottom {
    font-size: 0.85rem;
    opacity: 0.7;
    margin: 0;
    text-align: center;
  }
</style>
