---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const difficultyMeta = {
  beginner: { label: 'Beginner' },
  intermediate: { label: 'Intermediate' },
  advanced: { label: 'Advanced' },
} as const;

type Difficulty = keyof typeof difficultyMeta;

const difficultyRank: Record<Difficulty, number> = {
  beginner: 0,
  intermediate: 1,
  advanced: 2,
};

const storyThemes: Record<
  string,
  { kicker: string; accent: string; stamp: string }
> = {
  'four-great-inventions': {
    kicker: 'Innovation and craft',
    accent: 'var(--color-gold-leaf)',
    stamp: '甲',
  },
  'grand-canal': {
    kicker: 'Waterways and empire',
    accent: 'var(--color-jade)',
    stamp: '乙',
  },
  'mandate-of-heaven': {
    kicker: 'Ideas and legitimacy',
    accent: 'var(--color-vermillion)',
    stamp: '丙',
  },
  'silk-road': {
    kicker: 'Trade and exchange',
    accent: 'var(--color-gold-leaf)',
    stamp: '丁',
  },
  'terracotta-warriors': {
    kicker: 'Power and afterlife',
    accent: 'var(--color-vermillion)',
    stamp: '戊',
  },
  'zheng-he-voyages': {
    kicker: 'Ocean routes',
    accent: 'var(--color-jade)',
    stamp: '己',
  },
};

const tilts = ['-0.8deg', '0.6deg', '-0.35deg', '0.75deg'];

const stories = (await getCollection('stories'))
  .map((entry, index) => {
    const difficulty = entry.data.difficulty as Difficulty;
    const plainText = (entry.body ?? '')
      .replace(/^---[\s\S]*?---/, '')
      .replace(/[`*_>#-]/g, ' ')
      .replace(/\s+/g, ' ')
      .trim();
    const wordCount = plainText ? plainText.split(' ').length : 0;
    const readingTime = Math.max(3, Math.ceil(wordCount / 180));
    const visibleTags = (entry.data.tags ?? []).filter(
      (tag) => tag !== 'Language Learning'
    );
    const theme = storyThemes[entry.id] ?? {
      kicker: 'Historical reading',
      accent: 'var(--color-jade)',
      stamp: '史',
    };

    return {
      entry,
      difficulty,
      readingTime,
      wordCount,
      visibleTags,
      theme,
      tilt: tilts[index % tilts.length],
    };
  })
  .sort((a, b) => {
    const difficultyCompare = difficultyRank[a.difficulty] - difficultyRank[b.difficulty];
    if (difficultyCompare !== 0) return difficultyCompare;
    return b.entry.data.date.getTime() - a.entry.data.date.getTime();
  });
---

<BaseLayout
  title="Stories Preview — Archive Dossier | LoongLore"
  description="Concept preview: the stories archive reimagined as an archive of dossiers and folios."
>
  <main class="archive-page">
    <nav class="preview-switcher" aria-label="Design preview switcher">
      <span class="preview-switcher__label">Design previews</span>
      <a href="/design/stories-museum">Museum exhibit</a>
      <a href="/design/stories-timeline">Historical scroll</a>
      <a href="/design/stories-archive" aria-current="page">Archive dossier</a>
      <a href="/design/stories-editorial">Editorial magazine</a>
      <a href="/design/stories-bookshelf">Bookshelf hybrid</a>
      <a href="/stories">Current live page</a>
    </nav>

    <header class="archive-hero">
      <div class="archive-hero__copy">
        <p class="archive-kicker">Concept 03 · Archive dossier</p>
        <h1>Make the archive feel collected, filed, stamped, and treasured.</h1>
        <p class="archive-lede">
          This direction leans into labels, file tabs, seals, and paper layering. Each
          story feels like a treasured dossier pulled from a Chinese history cabinet.
        </p>
      </div>

      <div class="archive-hero__seal" aria-hidden="true">藏</div>
    </header>

    <section class="folio-stack" aria-label="Archive dossier concept">
      {stories.map((story, index) => (
        <a
          href={`/stories/${story.entry.id}`}
          class="folio-card"
          style={`--accent: ${story.theme.accent}; --tilt: ${story.tilt};`}
        >
          <span class="folio-card__tab">
            {difficultyMeta[story.difficulty].label}
          </span>

          <div class="folio-card__body">
            <span class="folio-card__stamp" aria-hidden="true">{story.theme.stamp}</span>

            <div class="folio-card__top">
              <span class="folio-card__index">{String(index + 1).padStart(2, '0')}</span>
              <span class="folio-card__kicker">{story.theme.kicker}</span>
            </div>

            <h2>{story.entry.data.title}</h2>
            <p>{story.entry.data.excerpt || story.entry.data.description}</p>

            <div class="folio-card__footer">
              <span>{story.readingTime} min · {story.wordCount} words</span>
              <span>{story.visibleTags.slice(0, 2).join(' · ')}</span>
            </div>
          </div>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .archive-page {
    max-width: 1120px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md) var(--space-3xl);
  }

  .preview-switcher {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: var(--space-xl);
  }

  .preview-switcher__label {
    font-size: var(--text-caption);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .preview-switcher a {
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--color-border-subtle);
    background: rgba(255, 255, 255, 0.45);
    color: var(--color-text-primary);
    text-decoration: none;
    font-size: var(--text-small);
    transition:
      transform var(--duration-fast) var(--ease-default),
      border-color var(--duration-fast) var(--ease-default);
  }

  .preview-switcher a[aria-current='page'] {
    background: var(--color-ink);
    border-color: var(--color-ink);
    color: var(--color-parchment);
  }

  .preview-switcher a:hover {
    transform: translateY(-1px);
    border-color: rgba(181, 65, 42, 0.3);
  }

  .archive-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) 9rem;
    gap: var(--space-xl);
    align-items: center;
    margin-bottom: var(--space-2xl);
    padding: clamp(1.4rem, 4vw, 2.8rem);
    border-radius: 30px;
    border: 1px solid rgba(28, 25, 23, 0.08);
    background:
      radial-gradient(circle at top right, rgba(181, 65, 42, 0.1), transparent 30%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.52), rgba(255, 255, 255, 0.15)),
      var(--color-bg);
    box-shadow: var(--shadow-sm);
  }

  .archive-kicker {
    margin: 0 0 var(--space-sm);
    font-size: var(--text-small);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand);
  }

  .archive-hero h1 {
    margin: 0 0 var(--space-md);
    max-width: 12ch;
    font-family: var(--font-display-en), serif;
    font-size: clamp(2.5rem, 6vw, 4.4rem);
    line-height: 1;
    color: var(--color-text-primary);
  }

  .archive-lede {
    margin: 0;
    max-width: 58ch;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .archive-hero__seal {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
    border-radius: 999px;
    background: rgba(181, 65, 42, 0.12);
    border: 1px solid rgba(181, 65, 42, 0.28);
    color: var(--color-brand);
    font-family: var(--font-display-cn), serif;
    font-size: 3rem;
  }

  .folio-stack {
    display: grid;
    gap: 0;
  }

  .folio-card {
    display: grid;
    grid-template-columns: 6rem minmax(0, 1fr);
    gap: 0;
    margin-top: -0.45rem;
    color: inherit;
    text-decoration: none;
    transform: rotate(var(--tilt));
    transition:
      transform var(--duration-fast) var(--ease-default),
      box-shadow var(--duration-fast) var(--ease-default);
  }

  .folio-card:first-child {
    margin-top: 0;
  }

  .folio-card:hover {
    transform: translateY(-4px) rotate(0deg);
  }

  .folio-card__tab {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-md);
    border: 1px solid rgba(28, 25, 23, 0.08);
    border-right: none;
    border-radius: 18px 0 0 18px;
    background: color-mix(in srgb, var(--accent) 12%, white);
    font-size: var(--text-caption);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }

  .folio-card__body {
    position: relative;
    overflow: hidden;
    padding: var(--space-lg) var(--space-xl);
    border: 1px solid rgba(28, 25, 23, 0.08);
    border-radius: 0 22px 22px 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.48), transparent 70%),
      color-mix(in srgb, var(--color-parchment) 90%, var(--accent) 6%);
    box-shadow: var(--shadow-md);
  }

  .folio-card__stamp {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
    background: color-mix(in srgb, var(--accent) 12%, white);
    font-family: var(--font-display-cn), serif;
    font-size: 1.3rem;
    color: var(--color-text-primary);
  }

  .folio-card__top,
  .folio-card__footer {
    display: flex;
    justify-content: space-between;
    gap: var(--space-sm);
    flex-wrap: wrap;
    color: var(--color-text-secondary);
    font-size: var(--text-small);
  }

  .folio-card__top {
    margin-bottom: var(--space-md);
  }

  .folio-card__index {
    font-family: var(--font-display-en), serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .folio-card__kicker {
    font-size: var(--text-caption);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .folio-card h2 {
    margin: 0 0 var(--space-sm);
    max-width: 18ch;
    font-family: var(--font-display-en), serif;
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    line-height: 1.08;
    color: var(--color-text-primary);
  }

  .folio-card p {
    margin: 0 0 var(--space-md);
    max-width: 60ch;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  @media (max-width: 900px) {
    .archive-hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .archive-page {
      padding-top: var(--space-lg);
    }

    .folio-card {
      grid-template-columns: 1fr;
      transform: none;
      margin-top: var(--space-md);
    }

    .folio-card__tab {
      writing-mode: horizontal-tb;
      border-right: 1px solid rgba(28, 25, 23, 0.08);
      border-bottom: none;
      border-radius: 18px 18px 0 0;
      justify-content: flex-start;
    }

    .folio-card__body {
      border-radius: 0 0 22px 22px;
    }
  }

  :global([data-theme='dark']) .preview-switcher a,
  :global([data-theme='dark']) .archive-hero,
  :global([data-theme='dark']) .folio-card__tab,
  :global([data-theme='dark']) .folio-card__body {
    border-color: rgba(255, 255, 255, 0.08);
  }

  :global([data-theme='dark']) .preview-switcher a {
    background: rgba(255, 255, 255, 0.04);
  }

  :global([data-theme='dark']) .archive-hero {
    background:
      radial-gradient(circle at top right, rgba(181, 65, 42, 0.1), transparent 30%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent 70%),
      var(--color-bg);
  }

  :global([data-theme='dark']) .folio-card__body {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent 70%),
      color-mix(in srgb, var(--color-surface) 92%, var(--accent) 8%);
  }
</style>
