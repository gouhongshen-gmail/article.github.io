---
import BaseLayout from '@layouts/BaseLayout.astro';
import VocabularyList from '@components/VocabularyList.svelte';
---

<BaseLayout title="My Vocabulary" description="Track and review your saved Chinese vocabulary words">
  <div class="vocab-page">
    <h1>My Vocabulary <span class="zh">我的词库</span></h1>
    <VocabularyList client:load />
  </div>
</BaseLayout>

<style>
  .vocab-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 32px 24px;
  }

  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.75rem;
    margin-bottom: 24px;
    color: var(--color-text-primary);
  }

  .zh {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.25rem;
    opacity: 0.7;
    margin-left: 8px;
  }

  @media (max-width: 640px) {
    .vocab-page {
      padding: 24px 16px;
    }

    h1 {
      font-size: 1.5rem;
      margin-bottom: 20px;
    }

    .zh {
      font-size: 1.1rem;
    }
  }
</style>
