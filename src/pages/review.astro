---
import BaseLayout from '@layouts/BaseLayout.astro';
import SrsReview from '@components/SrsReview.svelte';
---

<BaseLayout title="Review" description="Review your saved Chinese vocabulary with spaced repetition.">
  <div class="review-page">
    <SrsReview client:load />
  </div>
</BaseLayout>

<style>
  .review-page {
    min-height: calc(100vh - 256px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg, 1.5rem);
  }
</style>
