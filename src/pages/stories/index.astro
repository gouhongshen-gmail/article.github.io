---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const stories = (await getCollection('stories')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const difficultyStyle: Record<string, string> = {
  beginner: '--badge-bg: var(--color-jade)',
  intermediate: '--badge-bg: var(--color-gold-leaf); --badge-fg: #3d2e00',
  advanced: '--badge-bg: var(--color-vermillion)',
};

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout title="Stories | LongLore 龙知" description="Browse Chinese history stories for all levels — from the Grand Canal to Zheng He's voyages. Each story includes pinyin, glosses, and spaced repetition vocabulary.">
  <main class="stories-page">
    <header class="stories-header">
      <h1 class="stories-title">Stories <span class="zh">故事</span></h1>
    </header>

    {stories.length === 0 ? (
      <p class="empty-state">More stories coming soon!</p>
    ) : (
      <>
        <div class="filter-section">
          <div class="filter-bar">
            <button class="filter-pill active" data-filter="all">All</button>
            <button class="filter-pill" data-filter="beginner">Beginner</button>
            <button class="filter-pill" data-filter="intermediate">
              Intermediate
            </button>
            <button class="filter-pill" data-filter="advanced">Advanced</button>
            <input
              type="text"
              class="search-input"
              placeholder="Search by title or tags..."
              id="search-input"
            />
          </div>

          <div class="stats-line" id="stats-line">
            {stories.length} stories · {stories.filter((s) => s.data.difficulty === 'beginner').length} beginner ·
            {stories.filter((s) => s.data.difficulty === 'intermediate').length} intermediate ·
            {stories.filter((s) => s.data.difficulty === 'advanced').length} advanced
          </div>
        </div>

        <ul class="story-grid" role="list" id="story-grid">
          {stories.map((story) => (
            <li
              class="story-item"
              data-difficulty={story.data.difficulty}
              data-tags={story.data.tags.join(' ').toLowerCase()}
              data-title={story.data.title.toLowerCase()}
            >
              <a href={`/stories/${story.id}`} class="story-card">
                <div class="card-top">
                  <span
                    class="badge"
                    style={difficultyStyle[story.data.difficulty]}
                  >
                    {story.data.difficulty.charAt(0).toUpperCase() +
                      story.data.difficulty.slice(1)}
                  </span>

                  <h2 class="card-title">{story.data.title}</h2>

                  {(story.data.excerpt || story.data.description) && (
                    <p class="card-excerpt">
                      {story.data.excerpt || story.data.description}
                    </p>
                  )}
                </div>

                <div class="card-bottom">
                  {story.data.tags.length > 0 && (
                    <div class="tag-list">
                      {story.data.tags.map((tag: string) => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  )}
                  <time class="card-date" datetime={story.data.date.toISOString()}>
                    {formatDate(story.data.date)}
                  </time>
                </div>
              </a>
            </li>
          ))}
        </ul>

        <div class="no-results-message" id="no-results">
          No stories match your filters.
        </div>
      </>
    )}
  </main>
</BaseLayout>

<style>
  .stories-page {
    max-width: 960px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md);
  }

  .stories-header {
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .stories-title {
    font-family: var(--font-display-en), serif;
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.2;
  }

  .stories-title .zh {
    font-family: var(--font-display-zh, 'Noto Serif SC'), serif;
    margin-left: 0.25em;
    color: var(--color-text-secondary);
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    padding: var(--space-3xl) 0;
  }

  .filter-section {
    margin-bottom: 24px;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .filter-pill {
    padding: 6px 16px;
    border-radius: var(--radius-full);
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    font-family: inherit;
  }

  .filter-pill:hover {
    transform: translateY(-1px);
  }

  .filter-pill.active {
    background: var(--color-vermillion);
    color: white;
    border-color: var(--color-vermillion);
  }

  .search-input {
    width: 200px;
    height: 36px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0 16px;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 14px;
    font-family: inherit;
    transition: all 0.2s;
  }

  .search-input::placeholder {
    color: var(--color-text-secondary);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--color-vermillion);
    box-shadow: 0 0 0 3px rgba(220, 88, 50, 0.1);
  }

  @media (max-width: 640px) {
    .search-input {
      flex: 1;
      min-width: 150px;
    }
  }

  .stats-line {
    font-size: 14px;
    color: var(--color-text-secondary);
    margin-bottom: 16px;
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (min-width: 640px) {
    .story-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .story-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .story-item {
    transition: opacity 0.2s;
  }

  .story-item.hidden {
    display: none;
  }

  .story-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    background: var(--color-parchment);
    border: 1px solid rgba(28, 25, 23, 0.08);
    border-radius: 16px;
    padding: var(--space-lg);
    text-decoration: none;
    color: inherit;
    transition:
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .story-card:hover {
    box-shadow:
      0 4px 6px -1px rgba(28, 25, 23, 0.1),
      0 2px 4px -2px rgba(28, 25, 23, 0.1);
    transform: translateY(-2px);
  }

  .card-top {
    flex: 1;
  }

  .badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15em 0.65em;
    border-radius: 999px;
    background: var(--badge-bg);
    color: var(--badge-fg, #fff);
    margin-bottom: var(--space-sm);
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-xs);
  }

  .card-excerpt {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-bottom {
    margin-top: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35em;
  }

  .tag {
    font-size: 0.7rem;
    padding: 0.15em 0.55em;
    border-radius: 999px;
    background: rgba(28, 25, 23, 0.06);
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .card-date {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .no-results-message {
    display: none;
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 1rem;
    padding: var(--space-2xl) 0;
  }

  .no-results-message.visible {
    display: block;
  }

  /* Dark mode overrides */
  :global([data-theme='dark']) .story-card {
    background: var(--color-surface);
    border-color: rgba(255, 255, 255, 0.08);
  }

  :global([data-theme='dark']) .tag {
    background: rgba(255, 255, 255, 0.08);
  }

  :global([data-theme='dark']) .story-card:hover {
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.3),
      0 2px 4px -2px rgba(0, 0, 0, 0.2);
  }
</style>

<script is:inline>
  // Client-side filtering script
  const filterPills = document.querySelectorAll('.filter-pill');
  const searchInput = document.getElementById('search-input');
  const storyItems = document.querySelectorAll('.story-item');
  const noResultsMessage = document.getElementById('no-results');

  let currentFilter = 'all';
  let currentSearch = '';

  function applyFilters() {
    let visibleCount = 0;

    storyItems.forEach((item) => {
      const difficulty = item.getAttribute('data-difficulty');
      const tags = item.getAttribute('data-tags');
      const title = item.getAttribute('data-title');

      // Check difficulty filter
      const matchesDifficulty = currentFilter === 'all' || difficulty === currentFilter;

      // Check search filter
      const searchLower = currentSearch.toLowerCase();
      const matchesSearch =
        !currentSearch ||
        title.includes(searchLower) ||
        tags.includes(searchLower);

      // Apply visibility
      if (matchesDifficulty && matchesSearch) {
        item.classList.remove('hidden');
        visibleCount++;
      } else {
        item.classList.add('hidden');
      }
    });

    // Show/hide no results message
    if (visibleCount === 0) {
      noResultsMessage.classList.add('visible');
    } else {
      noResultsMessage.classList.remove('visible');
    }
  }

  // Filter pill click handlers
  filterPills.forEach((pill) => {
    pill.addEventListener('click', (e) => {
      const filter = e.target.getAttribute('data-filter');
      currentFilter = filter;

      // Update active state
      filterPills.forEach((p) => p.classList.remove('active'));
      e.target.classList.add('active');

      applyFilters();
    });
  });

  // Search input handler
  searchInput.addEventListener('input', (e) => {
    currentSearch = e.target.value;
    applyFilters();
  });
</script>
