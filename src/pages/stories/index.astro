  :global([data-theme='dark']) .library-stat,
  :global([data-theme='dark']) .hero-recommendation {
    border-color: rgba(255, 255, 255, 0.08);
  }

  :global([data-theme='dark']) .library-hero {
    background:
      radial-gradient(circle at top right, rgba(205, 164, 52, 0.12), transparent 34%),
      radial-gradient(circle at bottom left, rgba(35, 122, 99, 0.1), transparent 28%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01)),
      var(--color-bg);
  }

