---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const stories = (await getCollection('stories')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const difficultyColor: Record<string, string> = {
  beginner: 'var(--color-jade)',
  intermediate: 'var(--color-gold-leaf)',
  advanced: 'var(--color-vermillion)',
};

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout title="Stories | LongLore 龙知">
  <main class="stories-page">
    <header class="stories-header">
      <h1 class="stories-title">Stories <span class="zh">故事</span></h1>
    </header>

    {stories.length === 0 ? (
      <p class="empty-state">More stories coming soon!</p>
    ) : (
      <ul class="story-grid" role="list">
        {stories.map((story) => (
          <li>
            <a href={`/stories/${story.id}`} class="story-card">
              <div class="card-top">
                <span
                  class="badge"
                  style={`--badge-bg: ${difficultyColor[story.data.difficulty]}`}
                >
                  {story.data.difficulty.charAt(0).toUpperCase() +
                    story.data.difficulty.slice(1)}
                </span>

                <h2 class="card-title">{story.data.title}</h2>

                {(story.data.excerpt || story.data.description) && (
                  <p class="card-excerpt">
                    {story.data.excerpt || story.data.description}
                  </p>
                )}
              </div>

              <div class="card-bottom">
                {story.data.tags.length > 0 && (
                  <div class="tag-list">
                    {story.data.tags.map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
                <time class="card-date" datetime={story.data.date.toISOString()}>
                  {formatDate(story.data.date)}
                </time>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
</BaseLayout>

<style>
  .stories-page {
    max-width: 960px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md);
  }

  .stories-header {
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .stories-title {
    font-family: var(--font-display-en), serif;
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.2;
  }

  .stories-title .zh {
    font-family: var(--font-display-zh, 'Noto Serif SC'), serif;
    margin-left: 0.25em;
    color: var(--color-text-secondary);
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    padding: var(--space-3xl) 0;
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (min-width: 640px) {
    .story-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .story-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .story-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    background: var(--color-parchment);
    border: 1px solid rgba(28, 25, 23, 0.08);
    border-radius: 16px;
    padding: var(--space-lg);
    text-decoration: none;
    color: inherit;
    transition:
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .story-card:hover {
    box-shadow:
      0 4px 6px -1px rgba(28, 25, 23, 0.1),
      0 2px 4px -2px rgba(28, 25, 23, 0.1);
    transform: translateY(-2px);
  }

  .card-top {
    flex: 1;
  }

  .badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15em 0.65em;
    border-radius: 999px;
    background: var(--badge-bg);
    color: #fff;
    margin-bottom: var(--space-sm);
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-xs);
  }

  .card-excerpt {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-bottom {
    margin-top: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35em;
  }

  .tag {
    font-size: 0.7rem;
    padding: 0.15em 0.55em;
    border-radius: 999px;
    background: rgba(28, 25, 23, 0.06);
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .card-date {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  /* Dark mode overrides */
  :global([data-theme='dark']) .story-card {
    background: var(--color-surface);
    border-color: rgba(255, 255, 255, 0.08);
  }

  :global([data-theme='dark']) .tag {
    background: rgba(255, 255, 255, 0.08);
  }

  :global([data-theme='dark']) .story-card:hover {
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.3),
      0 2px 4px -2px rgba(0, 0, 0, 0.2);
  }
</style>
