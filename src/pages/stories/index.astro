      color-mix(in srgb, var(--color-surface) 90%, var(--story-accent) 10%)
    );
  }

  :global([data-theme='dark']) .story-feature__wash,
  :global([data-theme='dark']) .story-card__wash {
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--story-accent) 16%, transparent), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent 62%);
  }

  :global([data-theme='dark']) .tag {
    background: rgba(255, 255, 255, 0.08);
  }
</style>

<script is:inline>
  const filterPills = Array.from(document.querySelectorAll('.filter-pill'));
  const searchInput = document.getElementById('search-input');
  const storyItems = Array.from(document.querySelectorAll('.story-item'));
  const noResultsMessage = document.getElementById('no-results');
  const statsLine = document.getElementById('stats-line');

  let currentFilter = 'all';
  let currentSearch = '';

  function renderStats(visibleCount) {
    if (!statsLine) return;

    const filterLabel =
      currentFilter === 'all'
        ? 'all levels'
        : currentFilter.charAt(0).toUpperCase() + currentFilter.slice(1);
    const searchLabel = currentSearch ? ` · search: "${currentSearch}"` : '';
    statsLine.textContent = `Showing ${visibleCount} of ${storyItems.length} chronicles · ${filterLabel}${searchLabel}`;
  }

  function applyFilters() {
    let visibleCount = 0;

    storyItems.forEach((item) => {
      const difficulty = item.getAttribute('data-difficulty') || '';
      const searchable = item.getAttribute('data-search') || '';
      const matchesDifficulty = currentFilter === 'all' || difficulty === currentFilter;
      const matchesSearch =
        !currentSearch || searchable.includes(currentSearch.toLowerCase());

      if (matchesDifficulty && matchesSearch) {
        item.classList.remove('hidden');
        visibleCount += 1;
      } else {
        item.classList.add('hidden');
      }
    });

    if (noResultsMessage) {
      noResultsMessage.classList.toggle('visible', visibleCount === 0);
    }

    renderStats(visibleCount);
  }

  filterPills.forEach((pill) => {
    pill.addEventListener('click', () => {
      currentFilter = pill.getAttribute('data-filter') || 'all';
      filterPills.forEach((otherPill) => otherPill.classList.remove('active'));
      pill.classList.add('active');
      applyFilters();
    });
  });

  if (searchInput) {
    searchInput.addEventListener('input', (event) => {
      const target = event.target;
      currentSearch = target && 'value' in target ? target.value.trim() : '';
      applyFilters();
    });
  }

  applyFilters();
</script>
