---
import BaseLayout from '@layouts/BaseLayout.astro';
import SettingsView from '@components/SettingsView.svelte';
---
<BaseLayout title="Settings" description="Customize your LongLore learning experience">
  <div class="settings-page">
    <h1>Settings <span class="zh">设置</span></h1>
    <SettingsView client:load />
  </div>
</BaseLayout>

<style>
  .settings-page {
    max-width: 640px;
    margin: 0 auto;
    padding: 32px 24px;
  }
  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.75rem;
    margin-bottom: 32px;
  }
  .zh {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.25rem;
    opacity: 0.7;
    margin-left: 8px;
  }
</style>
